• external_components:
    - source:
        type: local
        path: components

  esphome:
    name: camera-knob-supermini
    friendly_name: Camera Knob SuperMini
    on_boot:
      priority: -100
      then:
        - delay: 1s
        - output.set_level:
            id: backlight_pwm
            level: 100%

  esp32:
    board: esp32-s3-devkitc-1
    framework:
      type: arduino

  psram:
    mode: quad
    speed: 40MHz

  logger:

  api:
    encryption:
      key: !secret api_encryption_key

  ota:
    - platform: esphome

  wifi:
    networks:
      - ssid: !secret wifi_ssid_primary
        password: !secret wifi_password_primary
      - ssid: !secret wifi_ssid_backup
        password: !secret wifi_password_backup
    ap:
      ssid: "CameraKnob Fallback Hotspot"
      password: !secret fallback_ap_password

  web_server:
    port: 80

  captive_portal:

  display_screenshot:
    display_id: my_display
    page_global: current_page

  http_request:
    verify_ssl: false

  online_image:
    - url: !secret front_camera_snapshot_portrait_url
      id: camera_snapshot_front
      format: PNG
      type: RGB
      update_interval: never
    - url: !secret garden_camera_snapshot_portrait_url
      id: camera_snapshot_garden
      format: PNG
      type: RGB
      update_interval: never

  time:
    - platform: homeassistant
      id: ha_time
      timezone: Europe/London

  globals:
    - id: camera_loading
      type: bool
      restore_value: no
      initial_value: 'false'
    - id: camera_error
      type: bool
      restore_value: no
      initial_value: 'false'
    - id: camera_selector
      type: int
      restore_value: no
      initial_value: '0'
    - id: current_page
      type: int
      restore_value: no
      initial_value: '0'
    - id: last_activity_ms
      type: unsigned long
      restore_value: no
      initial_value: '0'
    - id: camera_has_image
      type: bool
      restore_value: no
      initial_value: 'false'
    - id: is_night
      type: bool
      restore_value: no
      initial_value: 'false'

  color:
    - id: col_white
      red: 100%
      green: 100%
      blue: 100%
    - id: col_grey
      red: 50%
      green: 50%
      blue: 50%
    - id: col_red
      red: 100%
      green: 0%
      blue: 0%
    - id: col_green
      red: 0%
      green: 100%
      blue: 0%
    - id: col_orange
      red: 100%
      green: 60%
      blue: 0%
    - id: col_night_time
      red: 20%
      green: 20%
      blue: 25%
    - id: col_night_date
      red: 10%
      green: 10%
      blue: 12%
    - id: col_night_accent
      red: 30%
      green: 15%
      blue: 0%

  font:
    - file: "fonts/Roboto-Regular.ttf"
      id: font_small
      size: 18
    - file: "fonts/Roboto-Bold.ttf"
      id: font_medium
      size: 24
    - file: "fonts/Roboto_Condensed-Bold.ttf"
      id: font_clock
      size: 72
      glyphs: "0123456789:"
    - file: "fonts/Roboto-Regular.ttf"
      id: font_date
      size: 20
      glyphs: "0123456789 ABCDEFGHIJKLMNOPQRSTUVWXYZabcdefghijklmnopqrstuvwxyz"
    - file: "fonts/Roboto_Condensed-Bold.ttf"
      id: font_tiny
      size: 14

  output:
    - platform: ledc
      pin: GPIO5
      id: backlight_pwm
      frequency: 1000Hz

  number:
    - platform: template
      name: "Display Brightness"
      id: backlight_brightness
      min_value: 0
      max_value: 100
      step: 1
      unit_of_measurement: "%"
      optimistic: true
      restore_value: true
      initial_value: 100
      set_action:
        - output.set_level:
            id: backlight_pwm
            level: !lambda "return x / 100.0;"

  spi:
    clk_pin: GPIO12
    mosi_pin: GPIO13

  sensor:
    - platform: rotary_encoder
      id: rotary_knob
      pin_a:
        number: GPIO6
        mode: INPUT_PULLUP
      pin_b:
        number: GPIO4
        mode: INPUT_PULLUP
      min_value: -1
      max_value: 1
      resolution: 1
      publish_initial_value: false
      on_clockwise:
        then:
          - lambda: |-
              id(last_activity_ms) = millis();
              if (id(current_page) == 1 && id(camera_selector) != 1) {
                id(camera_selector) = 1;
                id(rotary_knob).set_value(0);
              }
          - if:
              condition:
                lambda: 'return id(current_page) == 1 && id(camera_selector) == 1;'
              then:
                - script.execute: fetch_selected_camera
      on_anticlockwise:
        then:
          - lambda: |-
              id(last_activity_ms) = millis();
              if (id(current_page) == 1 && id(camera_selector) != 0) {
                id(camera_selector) = 0;
                id(rotary_knob).set_value(0);
              }
          - if:
              condition:
                lambda: 'return id(current_page) == 1 && id(camera_selector) == 0;'
              then:
                - script.execute: fetch_selected_camera

  binary_sensor:
    - platform: gpio
      id: nav_button
      name: "Navigation Button"
      pin:
        number: GPIO2
        mode: INPUT_PULLUP
        inverted: true
      on_press:
        then:
          - lambda: |-
              id(last_activity_ms) = millis();
              if (id(current_page) == 0) {
                id(current_page) = 1;
                id(backlight_pwm).set_level(1.0f);
              } else {
                id(current_page) = 0;
                id(backlight_pwm).set_level(id(is_night) ? 0.08f : 1.0f);
              }
          - if:
              condition:
                lambda: 'return id(current_page) == 1;'
              then:
                - script.execute: fetch_selected_camera

    - platform: gpio
      id: knob_button
      name: "Knob Button"
      pin:
        number: GPIO7
        mode: INPUT_PULLUP
        inverted: true
      on_press:
        then:
          - lambda: |-
              id(last_activity_ms) = millis();
          - if:
              condition:
                lambda: 'return id(current_page) == 1;'
              then:
                - script.execute: fetch_selected_camera

    - platform: homeassistant
      id: front_person
      entity_id: binary_sensor.front_person
      on_press:
        then:
          - lambda: |-
              id(camera_selector) = 0;
              id(current_page) = 1;
              id(last_activity_ms) = millis();
              id(backlight_pwm).set_level(1.0f);
          - script.execute: fetch_selected_camera

  script:
    - id: fetch_selected_camera
      mode: restart
      then:
        - lambda: |-
            id(camera_loading) = true;
            id(camera_error) = false;
        - if:
            condition:
              lambda: 'return id(camera_selector) == 0;'
            then:
              - online_image.set_url:
                  id: camera_snapshot_front
                  url: !secret front_camera_snapshot_portrait_url
              - component.update: camera_snapshot_front
              - lambda: |-
                  id(camera_loading) = false;
                  id(camera_has_image) = true;
                  ESP_LOGI("camera", "Front camera snapshot loaded");
            else:
              - online_image.set_url:
                  id: camera_snapshot_garden
                  url: !secret garden_camera_snapshot_portrait_url
              - component.update: camera_snapshot_garden
              - lambda: |-
                  id(camera_loading) = false;
                  id(camera_has_image) = true;
                  ESP_LOGI("camera", "Garden camera snapshot loaded");

  interval:
    - interval: 1s
      then:
        - lambda: |-
            // Night mode: 22:00 - 07:00
            auto time = id(ha_time).now();
            if (time.is_valid()) {
              bool night = (time.hour >= 22 || time.hour < 7);
              if (night != id(is_night)) {
                id(is_night) = night;
                if (id(current_page) == 0) {
                  id(backlight_pwm).set_level(night ? 0.08f : 1.0f);
                }
              }
            }
            // Return to clock after 120s of inactivity on camera page
            if (id(current_page) == 1 && id(last_activity_ms) > 0) {
              if (millis() - id(last_activity_ms) > 120000) {
                id(current_page) = 0;
                id(backlight_pwm).set_level(id(is_night) ? 0.08f : 1.0f);
                ESP_LOGI("display", "Returning to clock (timeout)");
              }
            }

  display:
    - platform: ili9xxx
      id: my_display
      model: ST7789V
      invert_colors: true
      cs_pin: GPIO10
      dc_pin: GPIO9
      reset_pin: GPIO8
      data_rate: 40MHz
      update_interval: 1s
      lambda: |-
        const int W = 240;
        const int H = 320;

        if (id(current_page) == 0) {
          // Clock page
          it.fill(Color(0, 0, 0));
          bool night = id(is_night);
          auto time_col = night ? id(col_night_time) : id(col_white);
          auto date_col = night ? id(col_night_date) : id(col_grey);
          auto accent_col = night ? id(col_night_accent) : id(col_orange);

          auto time = id(ha_time).now();
          if (time.is_valid()) {
            it.strftime(W/2, H/2 - 20, id(font_clock), time_col, TextAlign::CENTER, "%H:%M", time);
            it.strftime(W/2, H/2 + 40, id(font_date), date_col, TextAlign::CENTER, "%A %d %b", time);
          } else {
            it.printf(W/2, H/2, id(font_medium), time_col, TextAlign::CENTER, "Waiting for HA...");
          }

          if (id(front_person).state) {
            it.filled_circle(W/2, H - 40, 6, accent_col);
            if (!night) {
              it.printf(W/2, H - 22, id(font_tiny), accent_col, TextAlign::CENTER, "Person detected");
            }
          }

        } else if (id(current_page) == 1) {
          // Camera page
          if (id(camera_loading)) {
            it.fill(Color(0, 0, 0));
            it.printf(W/2, H/2 - 10, id(font_medium), id(col_white), TextAlign::CENTER, "Loading...");
            it.printf(W/2, H/2 + 20, id(font_small), id(col_grey), TextAlign::CENTER, "Fetching camera");
          } else if (id(camera_has_image)) {
            if (id(camera_selector) == 0) {
              it.image(0, 0, id(camera_snapshot_front));
            } else {
              it.image(0, 0, id(camera_snapshot_garden));
            }

            int bx = 5, by = 5, bw = 52, bh = 16;
            if (id(camera_selector) == 0) {
              it.filled_rectangle(bx, by, bw, bh, id(col_white));
              it.printf(bx + bw/2, by + bh/2, id(font_tiny), Color(0,0,0), TextAlign::CENTER, "FRONT");
            } else {
              it.rectangle(bx, by, bw, bh, id(col_white));
              it.printf(bx + bw/2, by + bh/2, id(font_tiny), id(col_white), TextAlign::CENTER, "FRONT");
            }

            int by2 = by + bh + 3;
            if (id(camera_selector) == 1) {
              it.filled_rectangle(bx, by2, bw, bh, id(col_white));
              it.printf(bx + bw/2, by2 + bh/2, id(font_tiny), Color(0,0,0), TextAlign::CENTER, "BACK");
            } else {
              it.rectangle(bx, by2, bw, bh, id(col_white));
              it.printf(bx + bw/2, by2 + bh/2, id(font_tiny), id(col_white), TextAlign::CENTER, "BACK");
            }

            auto time = id(ha_time).now();
            if (time.is_valid()) {
              it.strftime(W/2, H - 8, id(font_tiny), id(col_white), TextAlign::CENTER, "%H:%M:%S", time);
            }
          } else {
            it.fill(Color(0, 0, 0));
            it.printf(W/2, H/2, id(font_medium), id(col_white), TextAlign::CENTER, "Press to load");
          }
        }
